{
  "name": "@arcis/node",
  "version": "1.0.0",
  "description": "One-line security middleware for Node.js apps.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "test:unit": "vitest run tests/index.test.ts",
    "test:integration": "vitest run tests/integration.test.ts",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "security",
    "express",
    "middleware",
    "xss",
    "sql-injection",
    "rate-limit",
    "sanitize",
    "validation",
    "csrf",
    "helmet",
    "nodejs",
    "arcis"
  ],
  "author": "Your Name",
  "license": "MIT",
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "express": "^4.18.2",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GagancM/arcis"
  },
  "bugs": {
    "url": "https://github.com/GagancM/arcis/issues"
  },
  "homepage": "https://github.com/GagancM/arcis#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}
