<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Shield</RootNamespace>
    <AssemblyName>Shield</AssemblyName>
    <Version>1.0.0</Version>
    <Authors>Shield Contributors</Authors>
    <Company>Aspect.dev</Company>
    <Product>Shield Security Library</Product>
    <Description>One-line security for .NET web applications - XSS prevention, SQL injection protection, rate limiting, and more</Description>
    <PackageProjectUrl>https://github.com/aspect.dev/shield</PackageProjectUrl>
    <RepositoryUrl>https://github.com/aspect.dev/shield</RepositoryUrl>
    <PackageTags>security;xss;sql-injection;rate-limiting;aspnet;middleware</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Http.Abstractions" Version="2.2.0" />
    <PackageReference Include="System.Text.Json" Version="8.0.0" />
  </ItemGroup>

</Project>
